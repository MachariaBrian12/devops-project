# DOCUMENTATION ONLY — do not commit with real values
# To create this secret in your cluster run:
#
#   kubectl create secret generic kk-payments-secrets \
#     --from-literal=DB_PASSWORD=<your-db-password> \
#     --from-literal=STRIPE_API_KEY=<your-stripe-key> \
#     --from-literal=JWT_SECRET=<your-jwt-secret> \
#     -n kijani-project
#
# Required keys:
#   DB_PASSWORD     - PostgreSQL database password
#   STRIPE_API_KEY  - Stripe secret key (sk_live_... or sk_test_...)
#   JWT_SECRET      - Secret for signing JSON Web Tokens (min 64 chars)
